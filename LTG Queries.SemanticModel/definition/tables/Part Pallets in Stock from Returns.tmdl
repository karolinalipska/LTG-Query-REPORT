	partition 'Part Pallets in Stock from Returns' = m
		mode: directQuery
		source =
				let
				    Source = Oracle.Database(LTG_BlueYonder_Server_Prod, [HierarchicalNavigation=true, Query="with inv as#(lf)(#(lf)select #(lf)iv.STOLOC ""Location"",#(lf)iv.LODNUM ""SSCC"",#(lf)iv.PRTNUM ""SKU"",#(lf)iv.PRT_CLIENT_ID ""Client ID"",#(lf)listagg(distinct iv.LOTNUM ,', ') ""Batch"",#(lf)listagg(distinct iv.expire_dte ,', ') ""Expiry Date"",#(lf)sum(iv.UNTQTY)           ""Qty In Stock"" ,#(lf)pr.untpal    ""MD Qty"",#(lf)pr.lngdsc    ""SKU Description""#(lf)from all_inventory_view iv#(lf)left join locmst lm#(lf)on iv.stoloc = lm.stoloc#(lf)left join#(lf)(#(lf)select#(lf)pfv.prtnum,#(lf)pfv.wh_id,#(lf)pfv.prt_client_id,#(lf)pfv.untpal,#(lf)pd.lngdsc#(lf)from prtftp_view pfv#(lf)left join prtdsc pd#(lf)on pfv.prtnum||'|'||pfv.prt_client_id||'|'||pfv.wh_id = pd.colval#(lf)where pfv.defftp_flg = 1 and pfv.wh_id = 'GB_5024'#(lf))pr#(lf)on iv.prtnum = pr.prtnum and iv.prt_client_id = pr.prt_client_id#(lf)where iv.lodnum not like 'PERM%'#(lf)and iv.lodnum not like '550%'#(lf)and iv.wrkref is null#(lf)and lm.arecod in ('WCS','WIDE')#(lf)and iv.untqty <> pr.untpal#(lf)group by#(lf)iv.STOLOC,#(lf)iv.LODNUM,#(lf)iv.PRTNUM,#(lf)iv.PRT_CLIENT_ID,#(lf)pr.untpal,#(lf)pr.lngdsc#(lf)),#(lf)ret as#(lf)(#(lf)select #(lf)        max(dlytrn.trndte -1 / 24) datetime,#(lf)        dlytrn.lodnum,#(lf)        dlytrn.tostol to_returns,#(lf)        sum(dlytrn.trnqty) trnqty#(lf)   from dlytrn#(lf)     where dlytrn.tostol like '%RETURNS%'#(lf)    and actcod in ('RCV', 'ASN_NONTRUST', 'PUT_UNDR')#(lf)        and dlytrn.prt_client_id in ('CID000001','CID013634')#(lf)    and dlytrn.lodnum||dlytrn.subnum#(lf)    not in#(lf)    (select lodnum||subnum#(lf)    from#(lf)    dlytrn#(lf)    where actcod = 'RVRCP')#(lf)    GROUP by#(lf)        dlytrn.lodnum,#(lf)        dlytrn.tostol#(lf)    )#(lf)select#(lf)inv.*,#(lf)ret.trnqty ""Received Qty"",#(lf)ret.datetime ""Received At""#(lf)from inv#(lf)join ret #(lf)on inv.""SSCC"" = ret.lodnum#(lf)and ret.trnqty <> inv.""MD Qty"""])
				in
				    Source

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

