	partition 'Mondelez FP/PP Pick' = m
		mode: directQuery
		source =
				let
				    Source = Oracle.Database(LTG_BlueYonder_Server_Prod, [HierarchicalNavigation=true, Query="SELECT#(lf)    wh_id,#(lf)    client_id,#(lf)    ordnum,#(lf)    entdte,#(lf)    ""Alloc Date"",#(lf)    ordtyp,#(lf)    prtnum,#(lf)    lngdsc ""Item Description"",#(lf)    ordqty,#(lf)    round(((trunc(ordqty / ""MD Qty"")* ""MD Qty"")/ordqty) * 100,2) ""% Expected"",#(lf)    round(((coalesce(""FP Allocated"", 0)* ""MD Qty"")/ordqty) * 100,2) ""% Allocated"",  #(lf)    ""MD Qty"",#(lf)    rule_nam,#(lf)    alc_search_path,#(lf)    invsts_prg,#(lf)    ""Expected Pallets""#(lf)    || '/'#(lf)    || ""Expected Cases"" ""Expected Pallets/Casses"",#(lf)    ""Pallet Alloc""#(lf)    || '/'#(lf)    || ""Cases Alloc""    ""Allocated Pallets/Casses"",#(lf)    ""FP Allocated"",#(lf)    ""PP Allocated"",#(lf)    CASE#(lf)        WHEN ""Expected Pallets"" = ""FP Allocated"" and ""Expected Cases"" = ""Cases Alloc"" and ordqty = ""Total Qty Alloc"" then 'Full Order As Expected'#(lf)        WHEN ""Expected Pallets"" = ""FP Allocated"" then 'Full Pallets As Expected'#(lf)        WHEN ordqty <> ""Total Qty Alloc"" then 'Not Fully Alocated'#(lf)        WHEN ordqty = ""Total Qty Alloc"" and ""Expected Pallets"" <> ""FP Allocated""  and ""PP Allocated"" <> 0 then 'Pallet Pick Part Pallets'#(lf)        WHEN ordqty = ""Total Qty Alloc"" and ""Expected Pallets"" <> ""FP Allocated""  and ""PP Allocated"" = 0 then 'Case Pick'#(lf)        else null end ""Allocation"",#(lf)    ""Total Qty Alloc""#(lf)FROM#(lf)    (#(lf)        SELECT#(lf)            o.wh_id,#(lf)            o.client_id,#(lf)            o.ordnum,#(lf)            o.entdte,#(lf)            nvl(pvl.""Alloc Date"", pvc.""Alloc Date"")                                           ""Alloc Date"",#(lf)            o.ordtyp,#(lf)            ol.prtnum,#(lf)            ol.ordqty,#(lf)            sl.shpqty,#(lf)            ol.ordqty - sl.shpqty                                                             AS ""Shortages"",#(lf)            ol.rule_nam,#(lf)            ol.alc_search_path,#(lf)            ol.invsts_prg,#(lf)            pfd1.ftpcod,#(lf)            pfd1.lngdsc,#(lf)            pfd1.untpal                                                                       ""MD Qty"",#(lf)            sl.schbat,#(lf)            trunc(ol.ordqty / pfd1.untpal)                                                    AS ""Expected Pallets"",#(lf)            round(((ol.ordqty / pfd1.untpal) - trunc(ol.ordqty / pfd1.untpal)) * pfd1.untpal) AS ""Expected Cases"",#(lf)            coalesce(pvl.""Pallet Alloc"", 0)                                                   AS ""Pallet Alloc"",#(lf)            coalesce(pvl.""FP Allocated"", 0)                                                   AS ""FP Allocated"",#(lf)            coalesce(pvl.""PP Allocated"", 0)                                                   AS ""PP Allocated"",#(lf)            coalesce(pvc.""Cases Alloc"", 0)                                                    AS ""Cases Alloc"",#(lf)            coalesce(pvl.""Pallet Qty Alloc"", 0) + coalesce(pvc.""Cases Alloc"", 0)              AS ""Total Qty Alloc""#(lf)        FROM#(lf)            ord           o#(lf)            LEFT JOIN ord_line      ol ON o.ordnum = ol.ordnum#(lf)            LEFT JOIN shipment_line sl ON ol.ordnum = sl.ordnum#(lf)                                          AND ol.ordlin = sl.ordlin#(lf)            LEFT JOIN (#(lf)                SELECT DISTINCT#(lf)                    pf.prtnum,#(lf)                    pd.lngdsc,#(lf)                    pf.ftpcod,#(lf)                    pf.defftp_flg,#(lf)                    pf.def_asset_typ,#(lf)                    pf.untpal#(lf)                FROM#(lf)                         prtftp_view pf#(lf)                    left join prtdsc pd#(lf)                    on pf.prtnum||'|'||pf.prt_client_id||'|'||pf.wh_id = pd.colval#(lf)                WHERE#(lf)                        pf.wh_id = 'GB_5024'#(lf)                        and pf.defftp_flg = 1#(lf)            )             pfd1 ON ol.prtnum = pfd1.prtnum#(lf)            LEFT JOIN (#(lf)                SELECT#(lf)                    pv.ordnum,#(lf)                    pv.ordlin,#(lf)                    COUNT(pv.pckqty)     AS ""Pallet Alloc"",#(lf)                    sum(""FP Allocated"") ""FP Allocated"",#(lf)                    sum(""PP Allocated"") ""PP Allocated"",#(lf)                    SUM(pv.pckqty)       AS ""Pallet Qty Alloc"",#(lf)                    MAX(""Alloc Date"") ""Alloc Date"",#(lf)                    pv.lodlvl,#(lf)                    pv.pcksts,#(lf)                    pv.prtnum#(lf)                FROM#(lf)(SELECT#(lf)                    pwv.ordnum,#(lf)                    pwv.ordlin,#(lf)                    pwv.pckqty,#(lf)                    case when pwv.pckqty = pfv.untpal then 1 else 0 end ""FP Allocated"",#(lf)                    case when pwv.pckqty <> pfv.untpal then 1 else 0 end ""PP Allocated"",#(lf)                    pwv.pckqty       AS ""Pallet Qty Alloc"",#(lf)                    pwv.adddte - 1 / 24 ""Alloc Date"",#(lf)                    pwv.lodlvl,#(lf)                    pwv.pcksts,#(lf)                    pwv.prtnum,#(lf)                    pfv.untpal#(lf)                FROM#(lf)                    pckwrk_view pwv#(lf)                    left join prtftp_view pfv#(lf)                    on pwv.prtnum = pfv.prtnum#(lf)                    and pfv.wh_id = 'GB_5024'#(lf)                    and pfv.defftp_flg = 1#(lf)                WHERE#(lf)                    pwv.lodlvl = 'L'#(lf))pv#(lf)                GROUP BY#(lf)                    pv.ordnum,#(lf)                    pv.ordlin,#(lf)                    pv.lodlvl,#(lf)                    pv.pcksts,#(lf)                    pv.prtnum#(lf)            )             pvl ON o.ordnum = pvl.ordnum and ol.ordlin = pvl.ordlin#(lf)                     AND ol.prtnum = pvl.prtnum#(lf)            LEFT JOIN (#(lf)                SELECT#(lf)                    pv.ordnum,#(lf)                    pv.ordlin,#(lf)                    SUM(pv.pckqty)       AS ""Cases Alloc"",#(lf)                    MAX(adddte - 1 / 24) ""Alloc Date"",#(lf)                    pv.lodlvl,#(lf)                    pv.pcksts,#(lf)                    pv.prtnum#(lf)                FROM#(lf)                    pckwrk_view pv#(lf)                WHERE#(lf)                    pv.lodlvl = 'S'#(lf)                GROUP BY#(lf)                    pv.ordnum,#(lf)                    pv.ordlin,#(lf)                    pv.lodlvl,#(lf)                    pv.pcksts,#(lf)                    pv.prtnum#(lf)            )             pvc ON o.ordnum = pvc.ordnum#(lf)                     AND ol.prtnum = pvc.prtnum#(lf)                     and ol.ordlin = pvc.ordlin#(lf)        WHERE#(lf)            pvl.""Alloc Date"" > sysdate - 28#(lf)            OR pvc.""Alloc Date"" > sysdate - 28#(lf)    )#(lf)WHERE client_id = 'CID013634'#(lf)#(lf)        ", CommandTimeout=#duration(0, 11, 0, 0)])
				in
				    Source

	annotation PBI_NavigationStepName = Navigation

