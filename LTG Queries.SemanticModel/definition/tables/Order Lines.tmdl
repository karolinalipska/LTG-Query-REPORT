	partition 'Order Lines' = m
		mode: directQuery
		source =
				let
				    Source = Oracle.Database(EMG_BlueYonder_Server_Prod, [HierarchicalNavigation=true, Query="select #(lf)CLIENT_ID ,#(lf)case #(lf)when client_id = 'CID001842' then 'KP' #(lf)when client_id = 'CID000001' then 'Mars' #(lf)when client_id = 'CID001607' then 'General Mills' #(lf)when client_id = 'CID011524' then 'TATA' #(lf)else client_id end ""Client Name"",#(lf)ORDNUM ,#(lf)ORDLIN ,#(lf)WH_ID ,#(lf)PRT_CLIENT_ID ,#(lf)PRTNUM ,#(lf)RULE_NAM ,#(lf)ORDQTY ,#(lf)PCKQTY ,#(lf)SHPQTY ,#(lf)ENTDTE-1/24 ""Entry Date"" ,#(lf)ORDINV ,#(lf)INVSTS_PRG ,#(lf)CANCELLED_FLG,#(lf)REACOD_CMNT#(lf) from ord_line#(lf) where trunc(entdte-1/24) >= to_timestamp('01/01/2026','dd/mm/yyyy')"])
				in
				    Source

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

